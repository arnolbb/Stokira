:root {
  --bg: #f6f7f9;
  --panel: #ffffff;
  --panel-soft: #f1f4f8;
  --line: #dbe1e8;
  --line-strong: #c8d0da;
  --text: #17202a;
  --muted: #5c6a7d;
  --soft: #556270;
  --accent: #087f5b;
  --accent-strong: #056b4d;
  --accent-soft: #e7f6f0;
  --danger: #c2413b;
  --danger-soft: #fdecea;
  --warning: #9a5c00;
  --warning-soft: #fff4dc;
  --info: #2c6fbb;
  --info-soft: #e8f1fb;
  --shadow: 0 18px 45px rgba(24, 34, 45, 0.08);
  --radius: 8px;
  --sidebar: 276px;
  --speed: 180ms;
}

* {
  box-sizing: border-box;
}

html {
  min-height: 100%;
}

body {
  min-height: 100dvh;
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family:
    "Segoe UI",
    system-ui,
    -apple-system,
    BlinkMacSystemFont,
    sans-serif;
  letter-spacing: 0;
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  cursor: pointer;
}

button:disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

.app-shell {
  display: grid;
  grid-template-columns: var(--sidebar) minmax(0, 1fr);
  min-height: 100dvh;
}

.sidebar {
  position: sticky;
  top: 0;
  height: 100dvh;
  display: flex;
  flex-direction: column;
  border-right: 1px solid var(--line);
  background: #fbfcfd;
}

.brand {
  padding: 24px;
  border-bottom: 1px solid var(--line);
}

.brand-mark {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand-logo {
  display: grid;
  width: 42px;
  height: 42px;
  place-items: center;
  border-radius: var(--radius);
  background: var(--accent);
  color: #fff;
}

.brand-logo svg {
  width: 22px;
  height: 22px;
}

.brand-title {
  margin: 0;
  font-size: 20px;
  font-weight: 750;
}

.brand-subtitle {
  margin: 2px 0 0;
  color: var(--muted);
  font-size: 13px;
}

.nav {
  display: grid;
  gap: 5px;
  padding: 18px 14px;
}

.nav-button {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  min-height: 42px;
  padding: 10px 12px;
  border: 1px solid transparent;
  border-radius: var(--radius);
  background: transparent;
  color: var(--muted);
  text-align: left;
  transition: background var(--speed), color var(--speed), border-color var(--speed);
}

.nav-button:hover {
  background: var(--panel-soft);
  color: var(--text);
}

.nav-button.active {
  border-color: #bfe6d8;
  background: var(--accent-soft);
  color: var(--accent-strong);
  font-weight: 650;
}

.nav-icon {
  display: grid;
  width: 24px;
  height: 24px;
  flex-shrink: 0;
  place-items: center;
  border-radius: 6px;
  background: rgba(8, 127, 91, 0.08);
  color: var(--accent-strong);
}

.nav-icon svg {
  width: 14px;
  height: 14px;
}

.sidebar-footer {
  margin-top: auto;
  padding: 16px;
  border-top: 1px solid var(--line);
}

.user-card {
  display: grid;
  gap: 6px;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--panel);
}

.user-name {
  font-weight: 700;
}

.user-role {
  color: var(--muted);
  font-size: 13px;
  text-transform: capitalize;
}

.main {
  min-width: 0;
  padding: 28px;
}

.topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 24px;
}

.page-kicker {
  margin: 0 0 6px;
  color: var(--accent-strong);
  font-size: 13px;
  font-weight: 750;
}

.page-title {
  margin: 0;
  font-size: clamp(28px, 4vw, 42px);
  line-height: 1.1;
  letter-spacing: 0;
  text-wrap: balance;
}

.page-desc {
  max-width: 740px;
  margin: 8px 0 0;
  color: var(--muted);
  line-height: 1.6;
}

.toolbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 40px;
  padding: 10px 14px;
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  background: var(--panel);
  color: var(--text);
  font-weight: 650;
  transition: background var(--speed), border-color var(--speed), transform 80ms;
}

.button svg {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.button:hover {
  border-color: var(--accent);
}

.button:active {
  transform: translateY(1px);
}

.button.primary {
  border-color: var(--accent);
  background: var(--accent);
  color: #fff;
}

.button.primary:hover {
  background: var(--accent-strong);
}

.button.danger {
  border-color: #efb6b2;
  background: var(--danger-soft);
  color: var(--danger);
}

.button.ghost {
  background: transparent;
}

.grid {
  display: grid;
  gap: 16px;
}

.metric-grid {
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
}

.content-grid {
  grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.8fr);
  margin-top: 18px;
}

.report-grid {
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.panel {
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--panel);
  box-shadow: var(--shadow);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 16px;
  border-bottom: 1px solid var(--line);
}

.panel-title {
  margin: 0;
  font-size: 16px;
  font-weight: 750;
}

.panel-subtitle {
  margin: 3px 0 0;
  color: var(--muted);
  font-size: 13px;
}

.panel-body {
  padding: 16px;
}

.metric {
  min-height: 118px;
  padding: 16px;
}

.metric-label {
  margin: 0;
  color: var(--muted);
  font-size: 13px;
}

.metric-value {
  margin: 12px 0 8px;
  font-size: 30px;
  font-weight: 780;
  line-height: 1;
}

.metric-note {
  color: var(--soft);
  font-size: 13px;
}

.metric.accent {
  background: linear-gradient(180deg, #ffffff, var(--accent-soft));
}

.metric.warn {
  background: linear-gradient(180deg, #ffffff, var(--warning-soft));
}

.metric.danger {
  background: linear-gradient(180deg, #ffffff, var(--danger-soft));
}

.filters {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 14px;
}

.input,
.select,
.textarea {
  min-height: 40px;
  width: 100%;
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  background: #fff;
  color: var(--text);
  outline: none;
}

.input,
.select {
  padding: 9px 11px;
}

.textarea {
  min-height: 88px;
  padding: 10px 11px;
  resize: vertical;
}

.input:focus,
.select:focus,
.textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(8, 127, 91, 0.14);
}

.field {
  display: grid;
  gap: 7px;
}

.field label {
  color: #344255;
  font-size: 13px;
  font-weight: 650;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.full {
  grid-column: 1 / -1;
}

.table-wrap {
  width: 100%;
  overflow: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
  white-space: nowrap;
}

th,
td {
  padding: 12px 14px;
  border-bottom: 1px solid var(--line);
  text-align: left;
  vertical-align: middle;
}

th {
  color: var(--muted);
  font-size: 12px;
  font-weight: 750;
  text-transform: uppercase;
}

td {
  font-size: 14px;
}

tr:last-child td {
  border-bottom: 0;
}

.badge {
  display: inline-flex;
  align-items: center;
  min-height: 24px;
  padding: 4px 8px;
  border-radius: 999px;
  background: var(--panel-soft);
  color: var(--muted);
  font-size: 12px;
  font-weight: 700;
}

.badge.good {
  background: var(--accent-soft);
  color: var(--accent-strong);
}

.badge.warn {
  background: var(--warning-soft);
  color: var(--warning);
}

.badge.danger {
  background: var(--danger-soft);
  color: var(--danger);
}

.badge.info {
  background: var(--info-soft);
  color: var(--info);
}

.row-actions {
  display: flex;
  gap: 8px;
}

.icon-button {
  display: inline-grid;
  width: 34px;
  height: 34px;
  place-items: center;
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  background: #fff;
  color: var(--text);
  transition: border-color var(--speed), background var(--speed);
}

.icon-button svg {
  width: 15px;
  height: 15px;
}

.icon-button:hover {
  border-color: var(--accent);
  background: var(--accent-soft);
}

.list {
  display: grid;
  gap: 10px;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #fff;
  transition: border-color var(--speed);
}

.list-item:hover {
  border-color: var(--line-strong);
}

.list-title {
  margin: 0;
  font-weight: 700;
}

.list-end {
  text-align: right;
}

.list-meta {
  margin: 3px 0 0;
  color: var(--muted);
  font-size: 13px;
}

.empty {
  display: grid;
  place-items: center;
  min-height: 220px;
  padding: 28px;
  border: 1px dashed var(--line-strong);
  border-radius: var(--radius);
  background: #fbfcfd;
  color: var(--muted);
  text-align: center;
}

.toast {
  position: fixed;
  right: 20px;
  bottom: 20px;
  z-index: 20;
  max-width: min(420px, calc(100vw - 40px));
  padding: 13px 15px;
  border: 1px solid #bfe6d8;
  border-radius: var(--radius);
  background: #f3fbf7;
  color: var(--accent-strong);
  box-shadow: var(--shadow);
  font-weight: 650;
  animation: toast-in 250ms ease-out;
}

.toast.out {
  animation: toast-out 200ms ease-in forwards;
}

@keyframes toast-in {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes toast-out {
  from { opacity: 1; transform: translateY(0); }
  to { opacity: 0; transform: translateY(12px); }
}

.toast.error {
  border-color: #efb6b2;
  background: var(--danger-soft);
  color: var(--danger);
}

.modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: grid;
  place-items: center;
  padding: 20px;
  background: rgba(13, 20, 30, 0.32);
  animation: fade-in 200ms ease-out;
}

.modal {
  width: min(720px, 100%);
  max-height: min(860px, calc(100dvh - 40px));
  overflow: auto;
  border-radius: var(--radius);
  background: #fff;
  box-shadow: 0 35px 90px rgba(13, 20, 30, 0.25);
  animation: modal-in 250ms ease-out;
}

.modal.confirm-modal {
  width: min(440px, 100%);
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes modal-in {
  from { opacity: 0; transform: translateY(16px) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.login-wrap {
  display: grid;
  min-height: 100dvh;
  grid-template-columns: minmax(0, 1fr) minmax(420px, 520px);
}

.login-visual {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 42px;
  background:
    linear-gradient(135deg, rgba(8, 127, 91, 0.92), rgba(20, 87, 74, 0.96)),
    radial-gradient(circle at 70% 20%, rgba(255, 255, 255, 0.28), transparent 34%);
  color: #fff;
}

.login-visual h1 {
  max-width: 760px;
  margin: 0;
  font-size: clamp(42px, 7vw, 78px);
  line-height: 1;
  letter-spacing: -0.01em;
  text-wrap: balance;
}

.login-visual p {
  max-width: 620px;
  color: rgba(255, 255, 255, 0.88);
  font-size: 18px;
  line-height: 1.6;
}

.login-card {
  display: grid;
  align-content: center;
  padding: 38px;
  background: #fff;
}

.login-card-inner {
  display: grid;
  gap: 18px;
}

.login-seeds {
  display: grid;
  gap: 8px;
  padding: 12px;
  border-radius: var(--radius);
  background: var(--panel-soft);
  color: var(--muted);
  font-size: 13px;
}

.mode-pill {
  display: inline-flex;
  width: fit-content;
  align-items: center;
  gap: 8px;
  padding: 6px 9px;
  border: 1px solid #bfe6d8;
  border-radius: 999px;
  background: var(--accent-soft);
  color: var(--accent-strong);
  font-size: 12px;
  font-weight: 750;
}

@media (max-width: 1180px) {
  .content-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 860px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: static;
    height: auto;
  }

  .nav {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .main {
    padding: 20px;
  }

  .topbar {
    flex-direction: column;
  }

  .toolbar {
    justify-content: flex-start;
  }

  .form-grid {
    grid-template-columns: 1fr;
  }

  .login-wrap {
    grid-template-columns: 1fr;
  }

  .login-visual {
    min-height: 360px;
  }
}

@media (max-width: 560px) {
  .nav {
    grid-template-columns: 1fr;
  }

  .main {
    padding: 16px;
  }

  .panel-header {
    align-items: flex-start;
    flex-direction: column;
  }
}



.confirm-body {
  padding: 24px;
}

.confirm-body p {
  margin: 0 0 6px;
  font-weight: 700;
  font-size: 16px;
}

.confirm-body span {
  color: var(--muted);
  font-size: 14px;
}

.confirm-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  padding: 14px 24px;
  border-top: 1px solid var(--line);
}

.empty-icon {
  margin-bottom: 8px;
  color: var(--soft);
}

.empty-icon svg {
  width: 36px;
  height: 36px;
  stroke-width: 1.5;
}

.empty-action {
  margin-top: 14px;
}
